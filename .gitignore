# Dependencies
/vendor/
/node_modules/

# Build output (runtime-only zips are generated, never committed)
/build/

# Playwright auth state + artifacts
/tests/e2e/.auth/
/test-results/
/playwright-report/

# PHPUnit run cache
.phpunit.result.cache

# composer.lock is intentionally not committed (this is a distributable plugin,
# not an app). package-lock.json IS committed so `npm ci` works in CI.
composer.lock

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
*.swp
.idea/
.vscode/
