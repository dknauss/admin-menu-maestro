{
	"name": "maestro",
	"version": "1.0.0",
	"private": true,
	"description": "Tooling for Maestro: The Inline Admin Menu Editor: wp-env, PHP integration tests, Playwright E2E.",
	"scripts": {
		"check:doc-links": "node bin/check-doc-links.mjs",
		"test:js": "node --test tests/js/*.mjs",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:clean": "wp-env clean all",
		"test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/maestro-menu-editor vendor/bin/phpunit -c phpunit-integration.xml.dist",
		"pretest:e2e": "wp-env run tests-cli wp plugin activate maestro-menu-editor/maestro-menu-editor.php",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"preplayground": "bash bin/build.sh",
		"playground": "npx @wp-playground/cli@latest server --mount-before-install=./build/maestro-menu-editor:/wordpress/wp-content/plugins/maestro-menu-editor --blueprint=playground/blueprint.json",
		"assets:banners": "OUT_DIR=.wordpress-org python3 .wordpress-org/source/build_final.py"
	},
	"devDependencies": {
		"@playwright/test": "^1.45.0",
		"@wordpress/env": "^10.6.0",
		"bootstrap-icons": "^1.13.1"
	}
}
