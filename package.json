{
	"name": "admin-menu-maestro",
	"version": "1.0.0",
	"private": true,
	"description": "Tooling for Admin Menu Maestro: wp-env, PHP integration tests, Playwright E2E.",
	"scripts": {
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:clean": "wp-env clean all",
		"test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/admin-menu-maestro vendor/bin/phpunit -c phpunit-integration.xml.dist",
		"pretest:e2e": "wp-env run tests-cli wp plugin activate admin-menu-maestro/admin-menu-maestro.php",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed"
	},
	"devDependencies": {
		"@playwright/test": "^1.45.0",
		"@wordpress/env": "^10.6.0",
		"@wordpress/scripts": "^30.5.0",
		"bootstrap-icons": "^1.13.1"
	}
}
