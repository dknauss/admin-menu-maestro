{
	"name": "danknauss/amx-inline-menu-editor",
	"description": "In-place editing of the WordPress admin menu — rename, reorder, dashicons, per-role visibility.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0",
		"wp-phpunit/wp-phpunit": "^6.4",
		"wp-coding-standards/wpcs": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"autoload-dev": {
		"psr-4": {
			"AMX\\Tests\\Unit\\": "tests/unit/",
			"AMX\\Tests\\Integration\\": "tests/integration/"
		}
	},
	"scripts": {
		"test:unit": "phpunit -c phpunit-unit.xml.dist",
		"test:integration": "phpunit -c phpunit-integration.xml.dist",
		"lint": "phpcs --standard=WordPress includes admin-menu-customizer.php"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
